# Analytics Dashboard — variables de entorno
#
# TODAS son server-only: se leen únicamente en el servidor (src/lib/server/config.ts)
# y NUNCA deben llevar el prefijo NEXT_PUBLIC_ (eso las expondría al cliente).
# Copiá este archivo a .env y completá los valores reales.

# RiderApp (Super Admin APIs)
RIDERAPP_BASE_URL=
RIDERAPP_API_KEY=

# DriverApp (Control Plane APIs)
DRIVERAPP_BASE_URL=
DRIVERAPP_API_KEY=

# Payments (Control Plane APIs)
PAYMENTS_BASE_URL=
PAYMENTS_API_KEY=

# Feedback (Analytics APIs — header x-api-key)
FEEDBACK_BASE_URL=
FEEDBACK_API_KEY=

# Promociones (Internal Services API)
PROMOCIONES_BASE_URL=
PROMOCIONES_API_KEY=

# Clerk (autenticación — solo usuarios con publicMetadata.role === "super-admin").
# Excepción al "no NEXT_PUBLIC": la publishable key está diseñada para el cliente.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=
